import React, { useContext } from 'react';
import { ToolListContext } from './toolListProvider';

function ToolListView() {
  const ctx = useContext(ToolListContext);
  const toolList = ctx?.toolList;
  const fetchToolList = ctx?.fetchToolList;

  if (!toolList) return <div>Loading tools...</div>;

  return (
    <div>
      <div style={{ marginBottom: 8 }}>
        <button onClick={fetchToolList}>Refresh</button>
      </div>

      {toolList.length === 0 ? (
        <div>No tools available</div>
      ) : (
        <ul>
          {toolList.map((tool) => (
            <li key={tool.id} style={{ marginBottom: 12 }}>
              <div>
                <strong>{tool.name}</strong>
                {tool.count}
                <button style={{ marginLeft: 8 }} onClick={() => alert(`Tool ID: ${tool.id}`)}>
                  Details
                </button>
              </div>
              {/*<pre style={{ whiteSpace: 'pre-wrap', margin: 0 }}>
                {JSON.stringify(tool, null, 2)}
              </pre>*/}
            </li>
          ))}
        </ul>
      )}
    </div>
  );
}

export default ToolListView;
