import React, { useState } from 'react';
import fetchHelper from '../fetchHelper';

function ToolCreateForm() {
  const [name, setName] = useState('');
  const [count, setCount] = useState(1);
  const [loading, setLoading] = useState(false);
  const [message, setMessage] = useState(null);

  async function handleSubmit(e) {
    e.preventDefault();
    setMessage(null);

    // Basic validation
    if (!name.trim()) {
      setMessage({ type: 'error', text: 'Name is required' });
      return;
    }
    if (isNaN(count) || Number(count) < 0) {
      setMessage({ type: 'error', text: 'Count must be 0 or greater' });
      return;
    }

    const payload = { name: name.trim(), count: Number(count) };
    setLoading(true);
    try {
      const res = await fetchHelper.tool.create(payload);
      if (res.ok) {
        setMessage({ type: 'success', text: 'Tool created successfully' });
        setName('');
        setCount(1);
      } else {
        setMessage({ type: 'error', text: `Server error: ${res.status}` });
      }
    } catch (err) {
      setMessage({ type: 'error', text: String(err) });
    } finally {
      setLoading(false);
    }
  }

  return (
    <div style={{ maxWidth: 600 }}>
      <h2>Create Tool</h2>
      <form onSubmit={handleSubmit}>
        <div style={{ marginBottom: 8 }}>
          <label style={{ display: 'block', fontWeight: 'bold' }}>Tool name</label>
          <input
            type="text"
            value={name}
            onChange={e => setName(e.target.value)}
            placeholder="Enter tool name"
            style={{ width: '100%', padding: 6 }}
          />
        </div>

        <div style={{ marginBottom: 8 }}>
          <label style={{ display: 'block', fontWeight: 'bold' }}>Tool count</label>
          <input
            type="number"
            value={count}
            onChange={e => setCount(e.target.value)}
            min="1"
            style={{ width: 120, padding: 6 }}
          />
        </div>

        <div>
          <button type="submit" disabled={loading}>
            {loading ? 'Creating...' : 'Create'}
          </button>
        </div>
      </form>

      {message && (
        <div style={{ marginTop: 12, color: message.type === 'error' ? 'crimson' : 'green' }}>
          {message.text}
        </div>
      )}
    </div>
  );
}

export default ToolCreateForm;
